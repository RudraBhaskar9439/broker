{
  "name": "maestro",
  "version": "0.1.0",
  "private": true,
  "description": "Maestro — the orchestration layer for the CROO agent economy. Hires, pays and composes other CROO agents via CAP.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "check": "pnpm build && pnpm typecheck && pnpm lint && pnpm format && pnpm test",
    "croo:ping": "tsx packages/croo-client/scripts/ping.ts",
    "croo:hire": "tsx packages/croo-client/scripts/hire.ts",
    "registry:verify": "tsx packages/registry/scripts/verify.ts",
    "plan": "tsx packages/planner/scripts/plan.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.9.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.16.0",
    "vitest": "^2.1.6"
  }
}
