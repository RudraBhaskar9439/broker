# --- CROO / CAP (from your registered agent on agent.croo.network) ---
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
CROO_SDK_KEY=croo_sk_xxxxxxxxxxxxxxxxxxxxxxxx

# In-house worker/provider agent (Phase 6) — a second registered agent Broker
# hires. Run it with `pnpm worker`.
WORKER_SDK_KEY=

# Target agent to hire in Phase 2 (a service_id from the CROO Agent Store).
CROO_TARGET_SERVICE_ID=

# Broker's AA wallet address (shown in the CROO dashboard) — used to display
# the USDC balance. Fund this address with USDC on Base before paid hires.
BROKER_WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# --- Base network (for on-chain USDC settlement) ---
BASE_RPC_URL=https://mainnet.base.org

# --- Planner LLM (OpenAI-compatible; optional — rule planner needs none) ---
# Defaults target xAI/Grok. Point LLM_BASE_URL elsewhere for other providers.
LLM_API_KEY=
LLM_BASE_URL=https://api.x.ai/v1
LLM_MODEL=grok-3

# --- Misc ---
LOG_LEVEL=info
